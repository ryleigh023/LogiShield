      "type": "timeseries",
      "title": "HTTP request rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (handler) (rate(http_requests_total[1m]))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request latency p95 (seconds)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "refId": "A" }
      ]
    },
